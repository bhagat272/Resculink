default_platform(:ios)

platform :ios do

  desc "Increment build number, build IPA, upload to TestFlight"
  lane :beta_and_upload do
    # 1️⃣ Increment Build Number
    latest_build = get_build_number(
      xcodeproj: "Resculink.xcodeproj"
    ).to_i + 1

    increment_build_number(
      build_number: latest_build
    )

    # 2️⃣ Detect Valid iOS SDK (iphoneos)
    latest_ios_sdk = "iphoneos"   # 🚀 USE THIS — always correct for iOS IPA build
    UI.message("📱 Using iOS SDK: #{latest_ios_sdk}")

    # 3️⃣ Build IPA
  build_app(
    scheme: "Resculink",
    workspace: "Resculink.xcworkspace",
    configuration: "Release",
    export_method: "app-store",
    output_directory: "build",
    output_name: "Resculink.ipa",
    destination: "generic/platform=iOS"
  )


    # 4️⃣ Use GitLab CI Variables for Auth
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_KEY_ID"],
      issuer_id: ENV["APP_STORE_ISSUER_ID"],
      key_content: ENV["APP_STORE_API_KEY_P8"],  # NO FILE NEEDED
      duration: 1200,
      in_house: false
    )

    # 5️⃣ Upload to TestFlight
    pilot(
      api_key: api_key,
      ipa: "./build/Resculink.ipa"
    )
  end


  desc "Upload an existing IPA to TestFlight"
  lane :upload_only do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_KEY_ID"],
      issuer_id: ENV["APP_STORE_ISSUER_ID"],
      key_content: ENV["APP_STORE_API_KEY_P8"],
      duration: 1200,
      in_house: false
    )

    pilot(
      api_key: api_key,
      ipa: "./build/Resculink.ipa"
    )
  end

end
